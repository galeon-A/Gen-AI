from pyspark.sql.functions import *
from pyspark.sql.window import Window

Bronze_DB = "pharma_bronze"
Silver_DB = "pharmacy_silver"

spark.sql(f"CREATE DATABASE IF NOT EXISTS {Silver_DB}")

claims_raw = spark.table(f"{Bronze_DB}.claims_raw")
claims_window = Window.partitionBy("claim_id").orderBy(col("bronze_timestamp").desc())

claims_silver = (
    claims_raw
    .withColumn("row_num", row_number().over(claims_window))
    .filter(col("row_num") == 1)
    .drop("row_num")
    .filter(col("patient_id").isNotNull())
    .withColumn("prescription_date", to_date("prescription_date"))
    .withColumn("claim_status", upper(trim(col("claim_status"))))
    .withColumn("claim_amount", round(col("claim_amount"), 2))
)

claims_silver.write.format("delta").mode("overwrite").saveAsTable(f"{Silver_DB}.claims_silver")

patients_raw = spark.table(f"{Bronze_DB}.patient_hub_raw")

patients_silver = (
    patients_raw
    .filter(col("patient_id").isNotNull())
    .dropDuplicates(["patient_id"])
    .withColumn("enrollment_date", to_date("enrollment_date"))
    .withColumn("therapy_start_date", to_date("therapy_start_date"))
    .withColumn("consent_flag",
                when(col("consent_flag").isin("True", "true", True), lit(True))
                .otherwise(lit(False)))
    # PHI masking
    .withColumn("case_manager_masked", sha2(col("case_manager"), 256))
    .drop("case_manager")
)

patients_silver.write.format("delta").mode("overwrite").saveAsTable(f"{Silver_DB}.patient_hub_clean")


providers_raw = spark.table(f"{Bronze_DB}.provider_master_raw")

providers_silver = (
    providers_raw
    .dropDuplicates(["provider_id", "effective_date"])
    .withColumn("effective_date", to_date("effective_date"))
    .withColumn("end_date", to_date("end_date"))
    .withColumn("is_current",
                when(col("end_date").isNull(), lit(True))
                .otherwise(lit(False)))
)

providers_silver.write.format("delta").mode("overwrite").saveAsTable(f"{Silver_DB}.provider_master_clean")

shipments_raw = spark.table(f"{Bronze_DB}.specialty_pharmacy_raw")

shipments_silver = (
    shipments_raw
    .filter(col("patient_id").isNotNull())
    .dropDuplicates(["shipment_id"])
    .withColumn("fill_date", to_date("fill_date"))
    .withColumn("shipment_status", upper(trim(col("shipment_status"))))
    .withColumn("delay_flag",
                when(col("delivery_delay_days") > 7, lit(True))
                .otherwise(lit(False)))
)

shipments_silver.write.format("delta").mode("overwrite").saveAsTable(f"{Silver_DB}.specialty_pharmacy_clean")

print("Silver Layer Completed Successfully")
