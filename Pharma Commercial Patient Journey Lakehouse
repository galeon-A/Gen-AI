def ingest_bronze(file_path, schema, table_name, source_name):
    # print(f"Ingesting{source_name}. . . ")

    df = (spark.read.format("csv")
          .option("header", True)
          .schema(schema)
          .load(file_path)
          )
    
    bronze_df = (
        df.withColumn("bronze_timestamp", current_timestamp())
          .withColumn("source", lit(source_name))
          # .withColumn("file_path", col("_metadata.file_path"))
    )
    (
        bronze_df.write.format("delta")
        .mode("overwrite")
        .option("overwriteSchema", "true")
        .saveAsTable(f"{Bronze_DB}.{table_name}")     
    )

ingest_bronze(
    claims_path,
    claims_schema,
    "claims_raw",
    "claims"
)

ingest_bronze(
    patients_path,
    patients_schema,
    "patient_hub_raw",
    "patient_hub"
)
ingest_bronze(
    providers_path,
    providers_schema,
    "provider_master_raw",
    "provider_master"
)
ingest_bronze(
    shipments_path,
    shipments_schema,
    "specialty_pharmacy_raw",
    "specialty_pharmacy"
)

