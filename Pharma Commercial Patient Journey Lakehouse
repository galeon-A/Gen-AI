import pandas as pd
import numpy as np
import random
from faker import Faker
from datetime import datetime, timedelta
import os

fake = Faker()
np.random.seed(42)
random.seed(42)


NUM_PATIENTS = 5000
NUM_PROVIDERS = 500
NUM_CLAIMS = 20000
NUM_SHIPMENTS = 12000

OUTPUT_DIR = "data"
os.makedirs(OUTPUT_DIR, exist_ok=True)


SPECIALTIES = [
    "Oncology", "Hematology", "Rheumatology",
    "Cardiology", "Neurology"
]

TERRITORIES = [
    "North", "South", "East", "West", "Central"
]

CLAIM_STATUSES = ["Approved", "Rejected", "Pending"]

REJECTION_REASONS = [
    "Prior Authorization Required",
    "Coverage Denied",
    "Invalid NDC",
    "Patient Ineligible",
    "Missing Information",
    None
]

SUPPORT_PROGRAMS = [
    "Copay Assistance",
    "Nurse Support",
    "Financial Assistance",
    "Adherence Program"
]

SHIPMENT_STATUSES = [
    "Delivered",
    "Delayed",
    "Cancelled",
    "In Transit"
]

NDC_CODES = [f"{random.randint(10000,99999)}-{random.randint(1000,9999)}" for _ in range(50)]
DIAGNOSIS_CODES = [f"C{random.randint(10,99)}.{random.randint(0,9)}" for _ in range(30)]
PAYERS = [f"PAYER_{i}" for i in range(1, 21)]


def random_date(start_days_ago=730, end_days_ago=0):
    start = datetime.today() - timedelta(days=start_days_ago)
    end = datetime.today() - timedelta(days=end_days_ago)
    return fake.date_between(start_date=start, end_date=end)


providers = []

for i in range(1, NUM_PROVIDERS + 1):
    providers.append({
        "provider_id": f"PRV{i:05d}",
        "npi": random.randint(1000000000, 9999999999),
        "provider_name": fake.name(),
        "specialty": random.choice(SPECIALTIES),
        "territory": random.choice(TERRITORIES),
        "active_flag": random.choice([True, True, True, False]),
        "effective_date": random_date(),
        "end_date": None
    })

providers_df = pd.DataFrame(providers)


patients = []

for i in range(1, NUM_PATIENTS + 1):
    enrollment_date = random_date()
    therapy_start = enrollment_date + timedelta(days=random.randint(1, 45))

    patients.append({
        "patient_id": f"PAT{i:06d}",
        "patient_age": random.randint(18, 85),
        "gender": random.choice(["Male", "Female"]),
        "state": fake.state(),
        "enrollment_date": enrollment_date,
        "support_program": random.choice(SUPPORT_PROGRAMS),
        "case_manager": fake.name(),
        "consent_flag": random.choice([True, True, True, False]),
        "therapy_start_date": therapy_start
    })

patients_df = pd.DataFrame(patients)


claims = []

for i in range(1, NUM_CLAIMS + 1):
    patient = random.choice(patients)
    provider = random.choice(providers)

    claim_status = random.choices(
        CLAIM_STATUSES,
        weights=[0.7, 0.2, 0.1]
    )[0]

    rejection_reason = None
    if claim_status == "Rejected":
        rejection_reason = random.choice(REJECTION_REASONS[:-1])

    claims.append({
        "claim_id": f"CLM{i:07d}",
        "patient_id": patient["patient_id"],
        "provider_id": provider["provider_id"],
        "ndc_code": random.choice(NDC_CODES),
        "diagnosis_code": random.choice(DIAGNOSIS_CODES),
        "prescription_date": random_date(),
        "payer_id": random.choice(PAYERS),
        "claim_status": claim_status,
        "claim_amount": round(random.uniform(500, 15000), 2),
        "rejection_reason": rejection_reason
    })

claims_df = pd.DataFrame(claims)

# Introduce duplicates for realism
duplicate_claims = claims_df.sample(frac=0.02, random_state=42)
claims_df = pd.concat([claims_df, duplicate_claims], ignore_index=True)


shipments = []

for i in range(1, NUM_SHIPMENTS + 1):
    patient = random.choice(patients)

    fill_date = random_date()
    delay = random.randint(0, 15)

    shipments.append({
        "shipment_id": f"SHP{i:07d}",
        "patient_id": patient["patient_id"],
        "fill_date": fill_date,
        "shipment_status": random.choices(
            SHIPMENT_STATUSES,
            weights=[0.65, 0.15, 0.05, 0.15]
        )[0],
        "refill_number": random.randint(0, 12),
        "delivery_delay_days": delay
    })

shipments_df = pd.DataFrame(shipments)


# Missing values
claims_df.loc[claims_df.sample(frac=0.01).index, "patient_id"] = None
patients_df.loc[patients_df.sample(frac=0.01).index, "consent_flag"] = None
shipments_df.loc[shipments_df.sample(frac=0.01).index, "shipment_status"] = None


providers_df.to_csv(f"{OUTPUT_DIR}/raw_provider_master.csv", index=False)
patients_df.to_csv(f"{OUTPUT_DIR}/raw_patient_hub.csv", index=False)
claims_df.to_csv(f"{OUTPUT_DIR}/raw_claims.csv", index=False)
shipments_df.to_csv(f"{OUTPUT_DIR}/raw_specialty_pharmacy.csv", index=False)

print("Synthetic pharma datasets created successfully:")
print(f"Providers: {providers_df.shape}")
print(f"Patients/HUB: {patients_df.shape}")
print(f"Claims: {claims_df.shape}")
print(f"Shipments: {shipments_df.shape}")

print(f"\nFiles saved in: {OUTPUT_DIR}/")

